# ---------------------------------------------------------------
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------

# --- Supabase ---
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# --- RapidAPI (Real-Time Product Search / Google Shopping) ---
# Get your key at https://rapidapi.com/letscrape-6baf62c0469b4c628/api/real-time-product-search
RAPIDAPI_KEY=<your-rapidapi-key>

# --- Flask ---
FLASK_DEBUG=false
PORT=5000

# --- CORS ---
# Comma-separated list of allowed origins.
# Local dev: keep as http://localhost:3000
# Production (Render dashboard): set to both values, e.g.:
#   http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
