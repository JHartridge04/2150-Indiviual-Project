# ---------------------------------------------------------------
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to version control.
# ---------------------------------------------------------------

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Flask ---
# Set to "true" to enable hot-reload / debug output
FLASK_DEBUG=false
PORT=5000

# --- CORS ---
# Comma-separated list of allowed origins, e.g. http://localhost:3000
# Defaults to * (all origins) when not set — restrict this in production!
CORS_ORIGINS=http://localhost:3000

# --- React (frontend) ---
# These REACT_APP_ variables are inlined at build time by Create React App.
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key
REACT_APP_API_BASE_URL=http://localhost:5000
